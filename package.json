{
  "name": "wedding-digital-saas",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant Wedding Digital SaaS platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "scan-secrets": "bash scripts/detect-secrets.sh",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.0.0"
}
