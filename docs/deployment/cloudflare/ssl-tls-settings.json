{
  "description": "Cloudflare SSL/TLS configuration for Wedding Digital SaaS production domains",
  "requirements": ["2.1", "2.2", "2.3", "2.4", "2.7"],
  "zone_settings": {
    "ssl": {
      "value": "strict",
      "description": "Full (Strict) mode: end-to-end encryption with origin certificate validation"
    },
    "min_tls_version": {
      "value": "1.2",
      "description": "Minimum TLS 1.2 — blocks deprecated TLS 1.0 and 1.1"
    },
    "tls_1_3": {
      "value": "on",
      "description": "Enable TLS 1.3 for improved performance and security"
    },
    "always_use_https": {
      "value": "on",
      "description": "Redirect all HTTP requests to HTTPS with 301 status code"
    },
    "automatic_https_rewrites": {
      "value": "on",
      "description": "Automatically rewrite HTTP URLs to HTTPS in page content (fix mixed content)"
    },
    "opportunistic_encryption": {
      "value": "on",
      "description": "Inform browsers that HTTPS is available via Alt-Svc header"
    },
    "security_header": {
      "strict_transport_security": {
        "enabled": true,
        "max_age": 31536000,
        "include_subdomains": true,
        "nosniff": true,
        "preload": false
      },
      "description": "HSTS: max-age=31536000 (1 year), includeSubDomains"
    }
  },
  "origin_certificate": {
    "type": "origin-rsa",
    "validity_days": 5475,
    "hostnames": [
      "*.{domain}",
      "{domain}",
      "dashboard.{domain}",
      "api.{domain}",
      "ws.{domain}",
      "scanner.{domain}"
    ],
    "description": "Cloudflare Origin CA certificate installed on Railway for end-to-end encryption"
  },
  "domains": [
    {
      "subdomain": "dashboard",
      "fqdn": "dashboard.{domain}",
      "application": "Dashboard App (Next.js)",
      "ssl_mode": "strict",
      "hsts": true,
      "https_redirect": true
    },
    {
      "subdomain": "*",
      "fqdn": "{event-slug}.{domain}",
      "application": "Invitation App (Next.js, ISR)",
      "ssl_mode": "strict",
      "hsts": true,
      "https_redirect": true
    },
    {
      "subdomain": "scanner",
      "fqdn": "scanner.{domain}",
      "application": "Scanner PWA (Next.js)",
      "ssl_mode": "strict",
      "hsts": true,
      "https_redirect": true
    },
    {
      "subdomain": "api",
      "fqdn": "api.{domain}",
      "application": "Fastify API Server",
      "ssl_mode": "strict",
      "hsts": true,
      "https_redirect": true
    },
    {
      "subdomain": "ws",
      "fqdn": "ws.{domain}",
      "application": "WebSocket Server (Socket.io)",
      "ssl_mode": "strict",
      "hsts": true,
      "https_redirect": true
    }
  ]
}
