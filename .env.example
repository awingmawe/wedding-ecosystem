# =============================================================================
# Wedding Digital SaaS — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# Production Domain Configuration
# =============================================================================
# Set this to your production domain (e.g., weddingdigital.id)
# All subdomain-based variables are derived from this.
PRODUCTION_DOMAIN=yourdomain.com

# =============================================================================
# Cloudflare R2 Storage
# =============================================================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=wedding-ecosystem

# CDN URL for serving media files (set after domain is live)
# Format: https://cdn.{PRODUCTION_DOMAIN}
R2_PUBLIC_URL=https://cdn.yourdomain.com

# =============================================================================
# Cloudflare Zone Configuration
# =============================================================================
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# =============================================================================
# Frontend URLs (Vercel-hosted)
# =============================================================================
# Dashboard app URL
NEXT_PUBLIC_DASHBOARD_URL=https://wedding-ecosystem-dashboard.vercel.app

# API URL used by frontend apps (Railway backend — update when deployed)
NEXT_PUBLIC_API_URL=https://your-api.railway.app

# WebSocket URL used by frontend apps (Railway backend — update when deployed)
NEXT_PUBLIC_WS_URL=https://your-ws.railway.app

# CDN URL for media assets in frontend
NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

# =============================================================================
# Backend API Configuration
# =============================================================================
NODE_ENV=production
PORT=4000

# =============================================================================
# Database (Supabase PostgreSQL)
# =============================================================================
# Direct connection (port 5432) — used for migrations and schema changes
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=verify-full
# Pooled connection via PgBouncer (port 6543) — used for application queries
# Falls back to DATABASE_URL if not set
DATABASE_POOLED_URL=postgresql://user:password@host:6543/dbname?sslmode=verify-full

# =============================================================================
# Redis (Upstash)
# =============================================================================
UPSTASH_REDIS_CACHE_URL=rediss://default:password@host:6379

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key

# =============================================================================
# Encryption (QR payload & PII)
# =============================================================================
AES_ENCRYPTION_KEY=your-aes-256-encryption-key

# =============================================================================
# CORS Configuration
# =============================================================================
# Per-app origin configuration (read by the API server)
DASHBOARD_ORIGIN=https://wedding-ecosystem-dashboard.vercel.app
INVITATION_ORIGIN=https://wedding-ecosystem-invitation.vercel.app
SCANNER_ORIGIN=https://wedding-ecosystem-scanner.vercel.app

# =============================================================================
# Cloudflare Worker Routes (for domain setup script)
# =============================================================================
# These are used by scripts/setup-production-domain.sh
# CDN Cache Worker script name (deployed via wrangler)
# CDN_CACHE_WORKER_NAME=wedding-cdn-cache
# Image Resizer Worker script name (deployed via wrangler)
# IMAGE_RESIZER_WORKER_NAME=image-resizer

# =============================================================================
# Vercel Configuration (for automated domain setup)
# =============================================================================
# Only needed if using scripts/setup-production-domain.sh for Vercel env updates
# VERCEL_TOKEN=your-vercel-token
# VERCEL_PROJECT_DASHBOARD=prj_xxx
# VERCEL_PROJECT_INVITATION=prj_xxx
# VERCEL_PROJECT_SCANNER=prj_xxx
